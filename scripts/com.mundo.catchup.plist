<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mundo.catchup</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/lap15964/.config/mundo-bot/mundo_catchup.py</string>
    </array>

    <!-- Run on login AND every hour (catch missed cron after sleep/shutdown) -->
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>3600</integer>

    <!-- USER env needed for claude CLI auth in non-interactive context -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>USER</key>
        <string>lap15964</string>
        <key>HOME</key>
        <string>/Users/lap15964</string>
        <key>TMPDIR</key>
        <string>/tmp</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/lap15964/Library/Logs/mundo-bot/catchup.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/lap15964/Library/Logs/mundo-bot/catchup.log</string>

    <key>ThrottleInterval</key>
    <integer>300</integer>
</dict>
</plist>
